{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "paths": {
      "@forumline/protocol": ["../protocol/src/index.ts"],
      "@forumline/central-services-client": ["../central-services-client/src/index.ts"]
    }
  },
  "include": ["src"]
}
