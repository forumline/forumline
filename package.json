{
  "name": "forumline",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "dev:app": "pnpm --filter forumline-central-services dev",
    "build": "pnpm -r run build",
    "clean": "pnpm -r --if-present run clean",
    "lint": "biome lint",
    "lint:go": "cd services/forumline-api && go run github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.11.2 run ./...",
    "format": "biome format --write",
    "format:check": "biome check",
    "test": "vitest run --exclude 'tests/**'",
    "test:e2e": "playwright test --config tests/playwright.config.ts",
    "test:e2e:ui": "playwright test --config tests/playwright.config.ts --ui",
    "test:e2e:smoke": "playwright test --config tests/playwright.config.ts --project=smoke",
    "api:coverage": "tsx ci/check-api-coverage.ts",
    "api:coverage:app": "tsx ci/check-api-coverage.ts --only forumline-api",
    "api:coverage:forum": "tsx ci/check-api-coverage.ts --only forum-engine",
    "api:coverage:strict": "tsx ci/check-api-coverage.ts --strict",
    "env:coverage": "tsx ci/check-env-coverage.ts",
    "env:coverage:strict": "tsx ci/check-env-coverage.ts --strict",
    "postinstall": "git config core.hooksPath ci/hooks"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@playwright/test": "^1.58.2",
    "turbo": "^2.8.17",
    "vitest": "^4.0.18",
    "yaml": "^2.8.2"
  }
}
