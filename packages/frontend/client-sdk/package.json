{
  "name": "@forumline/client-sdk",
  "version": "0.2.0",
  "description": "Forumline client SDK — API client, auth, real-time, and state management",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./client": "./src/client.ts",
    "./auth": "./src/auth.ts",
    "./event-stream": "./src/event-stream.ts",
    "./dm-store": "./src/dm-store.ts",
    "./presence": "./src/presence.ts",
    "./identity": "./src/identity.ts",
    "./push": "./src/push.ts",
    "./forum-discovery": "./src/forum-discovery.ts",
    "./native-bridge": "./src/native-bridge.ts",
    "./calls": "./src/calls.ts",
    "./forum-store": "./src/forum-store.ts"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "generate": "openapi-typescript ../../../services/forumline-api/openapi.yaml -o src/api.gen.ts",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch"
  },
  "dependencies": {
    "@forumline/protocol": "workspace:*",
    "nanostores": "^1.2.0",
    "oidc-client-ts": "^3.5.0",
    "openapi-fetch": "^0.17.0"
  },
  "peerDependencies": {
    "livekit-client": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "livekit-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "openapi-typescript": "^7.8.0",
    "typedoc": "^0.28.18",
    "typescript": "^6.0.2"
  },
  "files": [
    "src",
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/forumline/forumline.git",
    "directory": "packages/frontend/client-sdk"
  }
}
