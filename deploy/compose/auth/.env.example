# Zitadel Auth Server — auth.forumline.net
# Copy to .env.enc after encrypting with:
#   sops -e --input-type dotenv --output-type dotenv .env.example > .env.enc

# Postgres (Zitadel's own database)
POSTGRES_ADMIN_PASSWORD=change-me-strong-password

# Zitadel database user (unprivileged, for runtime)
ZITADEL_DB_PASSWORD=change-me-zitadel-db-password

# Masterkey: exactly 32 characters, encrypts secrets at rest
# Generate with: openssl rand -base64 24
# WARNING: cannot be changed after first init without losing all encrypted data
ZITADEL_MASTERKEY=change-me-exactly-32-characters!

# Admin user password (changed on first login)
ZITADEL_ADMIN_PASSWORD=change-me-initial-admin-password
