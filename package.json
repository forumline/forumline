{
  "name": "forumline",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "dev:app": "pnpm --filter forumline-central-services dev",
    "build": "pnpm -r run build",
    "clean": "pnpm -r --if-present run clean",
    "lint": "eslint .",
    "lint:go": "cd services/forumline-api && go run github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.11.2 run ./...",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --exclude 'tests/**'",
    "test:e2e": "playwright test --config tests/playwright.config.ts",
    "test:e2e:ui": "playwright test --config tests/playwright.config.ts --ui",
    "test:e2e:smoke": "playwright test --config tests/playwright.config.ts --project=smoke",
    "postinstall": "lefthook install"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "lefthook": "^2.1.3",
    "prettier": "^3.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.18"
  }
}
