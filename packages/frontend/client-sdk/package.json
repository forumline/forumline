{
  "name": "@forumline/client-sdk",
  "version": "0.2.0",
  "description": "Forumline client SDK — API client, auth, real-time, and state management",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "default": "./dist/auth.js"
    },
    "./event-stream": {
      "types": "./dist/event-stream.d.ts",
      "default": "./dist/event-stream.js"
    },
    "./dm-store": {
      "types": "./dist/dm-store.d.ts",
      "default": "./dist/dm-store.js"
    },
    "./presence": {
      "types": "./dist/presence.d.ts",
      "default": "./dist/presence.js"
    },
    "./identity": {
      "types": "./dist/identity.d.ts",
      "default": "./dist/identity.js"
    },
    "./push": {
      "types": "./dist/push.d.ts",
      "default": "./dist/push.js"
    },
    "./forum-discovery": {
      "types": "./dist/forum-discovery.d.ts",
      "default": "./dist/forum-discovery.js"
    },
    "./native-bridge": {
      "types": "./dist/native-bridge.d.ts",
      "default": "./dist/native-bridge.js"
    },
    "./calls": {
      "types": "./dist/calls.d.ts",
      "default": "./dist/calls.js"
    },
    "./forum-store": {
      "types": "./dist/forum-store.d.ts",
      "default": "./dist/forum-store.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch"
  },
  "dependencies": {
    "@forumline/protocol": "workspace:*"
  },
  "peerDependencies": {
    "livekit-client": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "livekit-client": {
      "optional": true
    }
  },
  "devDependencies": {
    "typedoc": "^0.28.17",
    "typescript": "^5.9.3"
  },
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/forumline/forumline.git",
    "directory": "packages/frontend/client-sdk"
  }
}
