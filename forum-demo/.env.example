# GoTrue Auth (routed through Go proxy at /auth/v1/*)
VITE_AUTH_ANON_KEY=your-gotrue-anon-jwt

# LiveKit
VITE_LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud

# Forumline Hub (federation, optional)
VITE_HUB_URL=https://app.forumline.net
VITE_HUB_SUPABASE_URL=https://app.forumline.net
VITE_HUB_SUPABASE_ANON_KEY=your-hub-anon-key
FORUMLINE_CLIENT_ID=your-oauth-client-id
FORUMLINE_CLIENT_SECRET=your-oauth-client-secret
HUB_JWT_SECRET=your-hub-jwt-secret
