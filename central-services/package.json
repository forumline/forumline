{
  "name": "forumline-central-services",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Forumline Central Services — neutral identity and forum registry service",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx --watch server/index.ts",
    "build": "vite build",
    "build:server": "esbuild server/index.ts --bundle --platform=node --target=node20 --outdir=dist-server --format=esm --external:@supabase/* --external:jsonwebtoken --external:web-push --external:hono --external:@hono/* --external:zod",
    "start": "node dist-server/index.js"
  },
  "dependencies": {
    "@johnvondrashek/forumline-central-services-client": "*",
    "@johnvondrashek/forumline-protocol": "*",
    "@johnvondrashek/forumline-react": "*",
    "@johnvondrashek/forumline-server-sdk": "*",
    "hono": "^4.7.0",
    "@hono/node-server": "^1.14.0",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.62.16",
    "jsonwebtoken": "^9.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/web-push": "^3.6.4",
    "@vercel/node": "^5.6.9",
    "esbuild": "^0.27.3",
    "tsx": "^4.19.0",
    "@vitejs/plugin-react": "^5.1.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
