# ---- Go build stage ----
FROM golang:1.25-alpine AS go-build

WORKDIR /app
COPY example-forum-instances-and-shared-forum-server/go.mod example-forum-instances-and-shared-forum-server/go.sum ./
RUN go mod download

COPY example-forum-instances-and-shared-forum-server/shared/ shared/
COPY example-forum-instances-and-shared-forum-server/forum/ forum/
COPY example-forum-instances-and-shared-forum-server/forum-a/main.go forum-a/main.go
RUN CGO_ENABLED=0 GOOS=linux go build -o /app/bin/forum ./forum-a/

# ---- Frontend build stage ----
FROM node:20-slim AS frontend-build

RUN corepack enable && corepack prepare pnpm@10.6.5 --activate

WORKDIR /app

# Copy example-forum-instances-and-shared-forum-server/forum-a (standalone, no workspace deps needed)
COPY example-forum-instances-and-shared-forum-server/forum-a/package.json example-forum-instances-and-shared-forum-server/forum-a/pnpm-lock.yaml* ./

# Install dependencies
RUN pnpm install --frozen-lockfile || pnpm install

# Copy source and build
COPY example-forum-instances-and-shared-forum-server/forum-a/ .
RUN pnpm run build

# ---- Production stage ----
FROM alpine:3.21

RUN apk add --no-cache ca-certificates

WORKDIR /app

COPY --from=go-build /app/bin/forum .
COPY --from=frontend-build /app/dist ./dist/

ENV PORT=3000
EXPOSE 3000

CMD ["./forum"]
