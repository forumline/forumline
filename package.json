{
  "name": "forumline",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "tauri": "tauri",
    "tauri:dev": "TAURI_DIR=desktop-and-mobile-tauri-apps tauri dev",
    "tauri:build": "TAURI_DIR=desktop-and-mobile-tauri-apps tauri build",
    "dev:app": "pnpm --filter forumline-central-services dev",
    "build": "pnpm -r run build",
    "clean": "pnpm -r --if-present run clean",
    "lint": "eslint .",
    "lint:go": "cd forumline-identity-and-federation-api && go run github.com/golangci/golangci-lint/v2/cmd/golangci-lint@v2.11.2 run ./...",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run"
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "prettier": "^3.0.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.0.18"
  }
}
