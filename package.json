{
  "name": "forumline",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": ["packages/protocol", "packages/server-sdk", "packages/central-services-client", "packages/core", "central-services"],
  "scripts": {
    "tauri": "tauri",
    "tauri:dev": "TAURI_DIR=native-app tauri dev",
    "tauri:build": "TAURI_DIR=native-app tauri build",
    "dev:hub": "npm run --prefix central-services dev",
    "build": "turbo run build",
    "clean": "npm run --workspaces --if-present clean",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "prettier": "^3.0.0",
    "turbo": "^2",
    "typescript-eslint": "^8.0.0"
  }
}
