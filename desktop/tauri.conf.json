{
  "$schema": "node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Forumline",
  "version": "0.1.0",
  "identifier": "com.forumchatvoice.desktop",
  "build": {
    "frontendDist": "https://forumline-hub.vercel.app",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "Forumline",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["forumline"]
      }
    }
  }
}
